++      oda_rule_predict_multiclass(x[i], rule_i, boundary = boundary_mode))
++  }
++
++  conf_raw <- oda_confusion_multiclass(y, y_pred, w = rep(1, n))
++  conf_w   <- oda_confusion_multiclass(
